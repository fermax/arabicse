# Environment variables for Arabic Secondary Edu Search API (Production template)

# PostgreSQL Database Connection URL
DATABASE_URL=postgresql://admin:admin@localhost:5433/arabic_se

# JWT token signature secret key (Choose a very strong random secret in production)
JWT_SECRET_KEY=your-very-secret-key-for-jwt-change-me

# Access token expiration time in minutes (default is 7 days)
ACCESS_TOKEN_EXPIRE_MINUTES=10080
